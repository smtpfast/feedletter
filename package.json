{
  "name": "feedletter",
  "version": "0.2.0",
  "description": "Turn an RSS feed or Markdown folder into a newsletter: curate in a browser studio and send with SMTPfast.",
  "type": "module",
  "bin": {
    "feedletter": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "preview": "tsx src/cli.ts preview",
    "studio": "tsx src/cli.ts studio",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "newsletter",
    "email",
    "rss",
    "markdown",
    "digest",
    "template",
    "smtpfast",
    "studio"
  ],
  "homepage": "https://github.com/smtpfast/feedletter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smtpfast/feedletter.git"
  },
  "bugs": {
    "url": "https://github.com/smtpfast/feedletter/issues"
  },
  "author": "SMTPfast",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "fast-xml-parser": "^4.5.0",
    "gray-matter": "^4.0.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
